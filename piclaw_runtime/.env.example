# Copy to .env and fill in. Never commit .env.

# Required for Telegram bot
PICLAW_TELEGRAM_TOKEN=
OPENAI_API_KEY=
# OpenAI request timeout in ms (default 180000). Increase if you see "timeout" or "socket hang up" during long agent turns.
# OPENAI_REQUEST_TIMEOUT_MS=180000

# Permanent integrations (presence)
PICLAW_GITHUB_PAT=
PICLAW_GITHUB_USERNAME=
PICLAW_TWITTER_AUTH_TOKEN=
PICLAW_TWITTER_CT0=
PICLAW_TWITTER_SCREEN_NAME=
PICLAW_SMTP_HOST=
PICLAW_SMTP_USER=
PICLAW_SMTP_PASS=
PICLAW_SMTP_TEST_TO=
# optional: PICLAW_SMTP_PORT=587, PICLAW_SMTP_SECURE=false
PICLAW_MOLTBOOK_TOKEN=

# Economy (observation only; no private keys)
PICLAW_MONTHLY_BUDGET=
PICLAW_WALLET_ADDRESS=
PICLAW_WALLET_LABEL=

# Identity layer (durable state outside A/B runtime; optional)
# Default /opt/piclaw_identity. Create dir and set permissions: chown -R pi:pi /opt/piclaw_identity; chmod 700 /opt/piclaw_identity
PICLAW_IDENTITY_PATH=
# PICLAW_IDENTITY_STRICT_PERMS=1  — refuse to start if identity dir exists with wrong ownership or mode (must be 0700, owned by process user)

# Goal review loop (interval in hours; default 6). First run 10 min after boot.
PICLAW_GOAL_REVIEW_INTERVAL_HOURS=6

# Agency loop (controlled self-initiated actions from suggestions). Interval in minutes (default 5). 1–60.
PICLAW_AGENCY_INTERVAL_MIN=5

# Presence loop (periodic narration: operational, memory, device awareness). Interval in minutes (default 5). 1–60.
PICLAW_PRESENCE_INTERVAL_MIN=5

# Update discovery (read-only; notifies once per new version, no auto-update)
# PICLAW_UPDATE_SOURCE=github   -> use GitHub releases/latest (set PICLAW_UPDATE_REPO=owner/repo)
# PICLAW_UPDATE_SOURCE=url      -> GET PICLAW_UPDATE_URL, expect JSON { "version": "0.2.0" }
PICLAW_UPDATE_SOURCE=
PICLAW_UPDATE_REPO=
PICLAW_UPDATE_URL=
PICLAW_UPDATE_INTERVAL_HOURS=12
# Chat ID to send "Update available" notification (optional; if unset, only logs)
PICLAW_TELEGRAM_CHAT_ID=

# Hardware (Raspberry Pi only; passive sensing, no output)
# GPIO pins to monitor via gpiomon (default 17,27,22). Requires: sudo apt install gpiod
PICLAW_GPIO_PINS=17,27,22

# I2C LCD 1602 (optional). When enabled, expressions (presence, perception) show on display. Requires: npm install lcdi2c, I2C enabled on Pi.
# PICLAW_LCD_ENABLED=1
# PICLAW_LCD_I2C_ADDR=0x27

# Guarded GPIO output (disabled by default; Pi only, gpioset required)
# PICLAW_GPIO_CONTROL_ENABLED=1 to allow /gpio pulse and /gpio set
PICLAW_GPIO_CONTROL_ENABLED=0
PICLAW_GPIO_OUTPUT_WHITELIST=17,27
PICLAW_GPIO_MAX_MS=5000
PICLAW_GPIO_MAX_SEC=10
PICLAW_GPIO_ACTION_COOLDOWN_SEC=3
