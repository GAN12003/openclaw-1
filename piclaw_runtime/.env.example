# Copy to .env and fill in. Never commit .env.

# Required for Telegram bot
PICLAW_TELEGRAM_TOKEN=

# AI chat: NVIDIA NIM (OpenAI-compatible). Get an API key at build.nvidia.com (nvapi-...).
# Defaults match Piclaw: integrate API + z-ai/glm4.7. Override model only if you use another NVIDIA model id.
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=z-ai/glm4.7
# OpenAI-compatible request timeout in ms (default 180000).
# OPENAI_REQUEST_TIMEOUT_MS=180000

# Permanent integrations (presence)
# GitHub PAT: optional. Use for Issues/API/HTTP integrations — not required for git+SSH if you use deploy keys.
# Fine-grained: limit to repos + Issues (contents) as needed.
PICLAW_GITHUB_PAT=
PICLAW_GITHUB_USERNAME=
# Default GitHub org for Issues/repos via API or gh (optional)
# PICLAW_GITHUB_ORG=pixelagents

# Git branch bootstrap (optional; see piclaw_runtime/docs/GITHUB-AGENTS.md). Used by scripts/piclaw/agent-git-bootstrap.sh
# PICLAW_AGENT_ID=deagent02
# PICLAW_GIT_CLONE_ROOT=/home/gan12003/src
# PICLAW_RUNTIME_REPO_SSH=git@github.com-piclaw:GAN12003/openclaw-1.git
# PICLAW_WORKSPACE_REPO_SSH=git@github.com-workspaces:GAN12003/workspaces.git
# Compare /showupdates against this ref (default origin/main)
# PICLAW_GIT_UPSTREAM_REF=origin/main
# Install root for agent-runtime-update.sh rsync target (default /opt/piclaw)
# PICLAW_RUNTIME_INSTALL=/opt/piclaw
PICLAW_TWITTER_AUTH_TOKEN=
PICLAW_TWITTER_CT0=
PICLAW_TWITTER_SCREEN_NAME=
PICLAW_SMTP_HOST=
PICLAW_SMTP_USER=
PICLAW_SMTP_PASS=
PICLAW_SMTP_TEST_TO=
# optional: PICLAW_SMTP_PORT=587, PICLAW_SMTP_SECURE=false
PICLAW_MOLTBOOK_TOKEN=

# Economy
PICLAW_MONTHLY_BUDGET=
# Legacy single wallet label (optional)
PICLAW_WALLET_ADDRESS=
PICLAW_WALLET_LABEL=
# Multi-chain observation (public addresses). Native balance probes use public RPCs (override URLs if needed).
# PICLAW_WALLET_ETH_ADDRESS=0x...
# PICLAW_WALLET_POLYGON_ADDRESS=0x...   (optional; defaults to ETH address if unset)
# PICLAW_WALLET_SOLANA_ADDRESS=...
# PICLAW_RPC_ETH_URL=https://cloudflare-eth.com
# PICLAW_RPC_POLYGON_URL=https://polygon-rpc.com
# PICLAW_RPC_SOLANA_URL=https://api.mainnet-beta.solana.com
# High risk: only with explicit opt-in. Never commit keys. Prefer hardware or off-Pi signing.
# PICLAW_WALLET_SIGNING_ENABLED=1
# PICLAW_WALLET_ETH_PRIVATE_KEY=
# PICLAW_WALLET_SOLANA_PRIVATE_KEY=
# Map chat completion total_tokens to budget_guard units (0 = disabled). Example 0.01 = 0.01 units per completion batch per 1k total tokens.
# PICLAW_OPENAI_BUDGET_UNITS_PER_1K_TOTAL=0

# Identity layer (durable state outside A/B runtime; optional)
# Default /opt/piclaw_identity. Create dir and set permissions: chown -R pi:pi /opt/piclaw_identity; chmod 700 /opt/piclaw_identity
PICLAW_IDENTITY_PATH=
# PICLAW_IDENTITY_STRICT_PERMS=1  — refuse to start if identity dir exists with wrong ownership or mode (must be 0700, owned by process user)

# Goal review loop (interval in hours; default 6). First run 10 min after boot.
PICLAW_GOAL_REVIEW_INTERVAL_HOURS=6

# Agency loop (controlled self-initiated actions from suggestions). Interval in minutes (default 5). 1–60.
PICLAW_AGENCY_INTERVAL_MIN=5

# Presence loop (periodic narration: operational, memory, device awareness). Interval in minutes (default 5). 1–60.
PICLAW_PRESENCE_INTERVAL_MIN=5

# Update discovery (read-only; notifies once per new version, no auto-update)
# PICLAW_UPDATE_SOURCE=github   -> use GitHub releases/latest (set PICLAW_UPDATE_REPO=owner/repo)
# PICLAW_UPDATE_SOURCE=url      -> GET PICLAW_UPDATE_URL, expect JSON { "version": "0.2.0" }
PICLAW_UPDATE_SOURCE=
PICLAW_UPDATE_REPO=
PICLAW_UPDATE_URL=
PICLAW_UPDATE_INTERVAL_HOURS=12
# Chat ID(s) for owner-only commands and optional update notifications (comma-separated for several chats)
PICLAW_TELEGRAM_CHAT_ID=
# Your numeric Telegram user id(s) — use in groups so /updateandrestart etc. work when chat id is not your DM (comma-separated)
# PICLAW_TELEGRAM_OWNER_USER_IDS=
# Max tool rounds per user message in chat (default 16, max 32). Raise if you often see "(agent loop limit reached)".
# PICLAW_CHAT_MAX_TOOL_ROUNDS=16

# Hardware (Raspberry Pi only; passive sensing, no output)
# GPIO pins to monitor via gpiomon (default 17,27,22). Requires: sudo apt install gpiod
PICLAW_GPIO_PINS=17,27,22

# I2C LCD 1602 (optional). When enabled, expressions (presence, perception) show on display. Requires: npm install lcdi2c, I2C enabled on Pi.
# PICLAW_LCD_ENABLED=1
# PICLAW_LCD_I2C_ADDR=0x27

# Guarded GPIO output (disabled by default; Pi only, gpioset required)
# PICLAW_GPIO_CONTROL_ENABLED=1 to allow /gpio pulse and /gpio set
PICLAW_GPIO_CONTROL_ENABLED=0
PICLAW_GPIO_OUTPUT_WHITELIST=17,27
PICLAW_GPIO_MAX_MS=5000
PICLAW_GPIO_MAX_SEC=10
PICLAW_GPIO_ACTION_COOLDOWN_SEC=3
